// 都市刑侦案件线索管理平台 - 数据模型
// 作者：刑侦系统开发组

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 案件信息表
model Case {
  id           String     @id @default(uuid())
  caseNumber   String     @unique
  title        String
  description  String
  caseType     String
  status       String
  priority     String
  location     String?
  occurTime    DateTime?
  reportTime   DateTime?
  caseManager  String?
  department   String?
  summary           String?
  caseAnalysis      String?
  personAnalysis    String?
  evidenceAnalysis  String?
  conclusion        String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  clues        Clue[]
  evidences    Evidence[]
  casePersons  CasePerson[]
  personRelations PersonRelation[]
  evidenceBorrows EvidenceBorrow[]
  evidenceBatches EvidenceBatch[] @relation("BatchCase")
  sourceRelations CaseRelation[] @relation("SourceCase")
  targetRelations CaseRelation[] @relation("TargetCase")
}

// 人员信息表
model Person {
  id           String     @id @default(uuid())
  name         String
  gender       String?
  age          Int?
  idCard       String?    @unique
  phone        String?
  address      String?
  occupation   String?
  description  String?
  avatar       String?
  personType   String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  casePersons  CasePerson[]
  cluePersons  CluePerson[]
  relationsAsSubject PersonRelation[] @relation("SubjectRelations")
  relationsAsObject  PersonRelation[] @relation("ObjectRelations")
}

// 案件-人员关联表
model CasePerson {
  id        String   @id @default(uuid())
  caseId    String
  personId  String
  role      String
  note      String?
  createdAt DateTime @default(now())

  case      Case     @relation(fields: [caseId], references: [id])
  person    Person   @relation(fields: [personId], references: [id])

  @@unique([caseId, personId])
}

// 人员关系表
model PersonRelation {
  id            String   @id @default(uuid())
  subjectId     String
  objectId      String
  relationType  String
  description   String?
  caseId        String?
  createdAt     DateTime @default(now())

  subjectPerson Person @relation("SubjectRelations", fields: [subjectId], references: [id])
  objectPerson  Person @relation("ObjectRelations", fields: [objectId], references: [id])
  case          Case?  @relation(fields: [caseId], references: [id])
}

// 线索信息表
model Clue {
  id          String     @id @default(uuid())
  caseId      String?
  clueNumber  String     @unique
  title       String
  content     String
  clueType    String
  source      String
  credibility String
  importance  String
  status      String
  location    String?
  findTime    DateTime?
  informant   String?
  handler     String?
  note        String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  case        Case?      @relation(fields: [caseId], references: [id])
  evidences   Evidence[]
  cluePersons CluePerson[]
  evidenceBorrows EvidenceBorrow[]
  evidenceBatches EvidenceBatch[] @relation("BatchClue")
}

// 线索-人员关联表
model CluePerson {
  id        String   @id @default(uuid())
  clueId    String
  personId  String
  relation  String
  note      String?
  createdAt DateTime @default(now())

  clue      Clue     @relation(fields: [clueId], references: [id])
  person    Person   @relation(fields: [personId], references: [id])

  @@unique([clueId, personId])
}

// 证据批次表
model EvidenceBatch {
  id          String     @id @default(uuid())
  batchNumber String     @unique
  name        String?
  description String?
  caseId      String?
  clueId      String?
  collectionMethod String?
  collector   String?
  collectTime DateTime?
  location    String?
  status      String     @default("已入库")
  totalCount  Int        @default(0)
  successCount Int       @default(0)
  failCount   Int        @default(0)
  operator    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  case        Case?      @relation("BatchCase", fields: [caseId], references: [id])
  clue        Clue?      @relation("BatchClue", fields: [clueId], references: [id])
  evidences   Evidence[]
}

// 证据附件表
model Evidence {
  id          String     @id @default(uuid())
  batchId     String?
  caseId      String?
  clueId      String?
  evidenceNumber String  @unique
  name        String
  description String?
  type        String
  filePath    String
  fileName    String
  fileSize    Int?
  mimeType    String?
  hash        String?
  collectionMethod String?
  collector   String?
  collectTime DateTime?
  location    String?
  status      String
  borrowStatus String?  @default("未借阅")
  currentBorrower String?
  borrowTime  DateTime?
  note        String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  batch       EvidenceBatch? @relation(fields: [batchId], references: [id])
  case        Case?      @relation(fields: [caseId], references: [id])
  clue        Clue?      @relation(fields: [clueId], references: [id])
  borrowRecords EvidenceBorrow[]
}

// 证据借阅记录表
model EvidenceBorrow {
  id          String     @id @default(uuid())
  evidenceId  String
  caseId      String?
  clueId      String?
  borrower    String
  borrowerDepartment String?
  borrowReason String
  borrowTime  DateTime   @default(now())
  expectedReturnTime DateTime?
  actualReturnTime DateTime?
  status      String     @default("借阅中")
  returnNote  String?
  operator    String?
  returnOperator String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  evidence    Evidence   @relation(fields: [evidenceId], references: [id])
  case        Case?      @relation(fields: [caseId], references: [id])
  clue        Clue?      @relation(fields: [clueId], references: [id])
}

// 操作日志表
model OperationLog {
  id          String     @id @default(uuid())
  targetType  String
  targetId    String
  action      String
  description String?
  operator    String?
  operatorDepartment String?
  beforeData  String?
  afterData   String?
  ip          String?
  userAgent   String?
  createdAt   DateTime   @default(now())

  @@index([targetType, targetId])
  @@index([action])
  @@index([createdAt])
}

model CaseRelation {
  id            String   @id @default(uuid())
  sourceCaseId  String
  targetCaseId  String
  relationType  String   @default("专题关联")
  description   String?
  createdAt     DateTime @default(now())

  sourceCase    Case     @relation("SourceCase", fields: [sourceCaseId], references: [id])
  targetCase    Case     @relation("TargetCase", fields: [targetCaseId], references: [id])

  @@unique([sourceCaseId, targetCaseId])
}
