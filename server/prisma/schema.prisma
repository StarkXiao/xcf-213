// 都市刑侦案件线索管理平台 - 数据模型
// 作者：刑侦系统开发组

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 案件信息表
model Case {
  id           String     @id @default(uuid())
  caseNumber   String     @unique
  title        String
  description  String
  caseType     String
  status       String
  priority     String
  location     String?
  occurTime    DateTime?
  reportTime   DateTime?
  caseManager  String?
  department   String?
  summary           String?
  caseAnalysis      String?
  personAnalysis    String?
  evidenceAnalysis  String?
  conclusion        String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  clues        Clue[]
  evidences    Evidence[]
  casePersons  CasePerson[]
  personRelations PersonRelation[]
  evidenceBorrows EvidenceBorrow[]
  evidenceBatches EvidenceBatch[] @relation("BatchCase")
  sourceRelations CaseRelation[] @relation("SourceCase")
  targetRelations CaseRelation[] @relation("TargetCase")
  commandTasks CommandTask[]
}

// 人员信息表
model Person {
  id           String     @id @default(uuid())
  name         String
  gender       String?
  age          Int?
  idCard       String?    @unique
  phone        String?
  address      String?
  occupation   String?
  description  String?
  avatar       String?
  personType   String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  casePersons  CasePerson[]
  cluePersons  CluePerson[]
  relationsAsSubject PersonRelation[] @relation("SubjectRelations")
  relationsAsObject  PersonRelation[] @relation("ObjectRelations")
  personTags   PersonTag[]
  commandTasks CommandTask[]
}

// 案件-人员关联表
model CasePerson {
  id        String   @id @default(uuid())
  caseId    String
  personId  String
  role      String
  note      String?
  createdAt DateTime @default(now())

  case      Case     @relation(fields: [caseId], references: [id])
  person    Person   @relation(fields: [personId], references: [id])

  @@unique([caseId, personId])
}

// 人员关系表
model PersonRelation {
  id            String   @id @default(uuid())
  subjectId     String
  objectId      String
  relationType  String
  description   String?
  caseId        String?
  createdAt     DateTime @default(now())

  subjectPerson Person @relation("SubjectRelations", fields: [subjectId], references: [id])
  objectPerson  Person @relation("ObjectRelations", fields: [objectId], references: [id])
  case          Case?  @relation(fields: [caseId], references: [id])
}

// 线索信息表
model Clue {
  id          String     @id @default(uuid())
  caseId      String?
  clueNumber  String     @unique
  title       String
  content     String
  clueType    String
  source      String
  credibility String
  importance  String
  status      String
  location    String?
  findTime    DateTime?
  informant   String?
  handler     String?
  note        String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  case        Case?      @relation(fields: [caseId], references: [id])
  evidences   Evidence[]
  cluePersons CluePerson[]
  evidenceBorrows EvidenceBorrow[]
  evidenceBatches EvidenceBatch[] @relation("BatchClue")
  verifications ClueVerification[]
  commandTasks CommandTask[]
}

// 线索-人员关联表
model CluePerson {
  id        String   @id @default(uuid())
  clueId    String
  personId  String
  relation  String
  note      String?
  createdAt DateTime @default(now())

  clue      Clue     @relation(fields: [clueId], references: [id])
  person    Person   @relation(fields: [personId], references: [id])

  @@unique([clueId, personId])
}

// 证据批次表
model EvidenceBatch {
  id          String     @id @default(uuid())
  batchNumber String     @unique
  name        String?
  description String?
  caseId      String?
  clueId      String?
  collectionMethod String?
  collector   String?
  collectTime DateTime?
  location    String?
  status      String     @default("已入库")
  totalCount  Int        @default(0)
  successCount Int       @default(0)
  failCount   Int        @default(0)
  operator    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  case        Case?      @relation("BatchCase", fields: [caseId], references: [id])
  clue        Clue?      @relation("BatchClue", fields: [clueId], references: [id])
  evidences   Evidence[]
}

// 证据附件表
model Evidence {
  id                 String              @id @default(uuid())
  batchId            String?
  caseId             String?
  clueId             String?
  clueVerificationId String?
  evidenceNumber     String              @unique
  name               String
  description        String?
  type               String
  filePath           String
  fileName           String
  fileSize           Int?
  mimeType           String?
  hash               String?
  collectionMethod   String?
  collector          String?
  collectTime        DateTime?
  location           String?
  status             String
  borrowStatus       String?             @default("未借阅")
  currentBorrower    String?
  borrowTime         DateTime?
  note               String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  batch              EvidenceBatch?      @relation(fields: [batchId], references: [id])
  case               Case?               @relation(fields: [caseId], references: [id])
  clue               Clue?               @relation(fields: [clueId], references: [id])
  clueVerification   ClueVerification?   @relation(fields: [clueVerificationId], references: [id])
  borrowRecords      EvidenceBorrow[]
  commandTasks       CommandTask[]
}

// 证据借阅记录表
model EvidenceBorrow {
  id          String     @id @default(uuid())
  evidenceId  String
  caseId      String?
  clueId      String?
  borrower    String
  borrowerDepartment String?
  borrowReason String
  borrowTime  DateTime   @default(now())
  expectedReturnTime DateTime?
  actualReturnTime DateTime?
  status      String     @default("借阅中")
  returnNote  String?
  operator    String?
  returnOperator String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  evidence    Evidence   @relation(fields: [evidenceId], references: [id])
  case        Case?      @relation(fields: [caseId], references: [id])
  clue        Clue?      @relation(fields: [clueId], references: [id])
}

// 线索核查记录表
model ClueVerification {
  id            String     @id @default(uuid())
  clueId        String
  result        String
  attachmentIds String?
  handler       String?
  handleTime    DateTime?
  note          String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  clue          Clue       @relation(fields: [clueId], references: [id])
  evidences     Evidence[]

  @@index([clueId])
  @@index([createdAt])
}

// 操作日志表
model OperationLog {
  id          String     @id @default(uuid())
  targetType  String
  targetId    String
  action      String
  description String?
  operator    String?
  operatorDepartment String?
  beforeData  String?
  afterData   String?
  ip          String?
  userAgent   String?
  createdAt   DateTime   @default(now())

  @@index([targetType, targetId])
  @@index([action])
  @@index([createdAt])
}

model CaseRelation {
  id            String   @id @default(uuid())
  sourceCaseId  String
  targetCaseId  String
  relationType  String   @default("专题关联")
  description   String?
  createdAt     DateTime @default(now())

  sourceCase    Case     @relation("SourceCase", fields: [sourceCaseId], references: [id])
  targetCase    Case     @relation("TargetCase", fields: [targetCaseId], references: [id])

  @@unique([sourceCaseId, targetCaseId])
}

model Tag {
  id          String   @id @default(uuid())
  name        String
  category    String
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  personTags  PersonTag[]

  @@unique([name, category])
}

model PersonTag {
  id        String   @id @default(uuid())
  personId  String
  tagId     String
  createdAt DateTime @default(now())

  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([personId, tagId])
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  OVERDUE
}

enum TaskType {
  CASE_INVESTIGATION
  CLUE_VERIFICATION
  EVIDENCE_COLLECTION
  PERSON_INTERROGATION
  ANALYSIS_REPORT
  COORDINATION
  OTHER
}

enum FlowAction {
  ASSIGN
  TRANSFER
  RECEIVE
  RETURN
  APPROVE
  REJECT
  ARCHIVE
  UNARCHIVE
}

enum ClueCheckStatus {
  REGISTERED
  DISPATCHED
  VERIFYING
  FEEDBACKED
  ADOPTED
  REJECTED
  CLOSED
}

enum ClueCheckStage {
  REGISTER
  DISPATCH
  VERIFY
  FEEDBACK
  ADOPT
}

model ClueCheckFlow {
  id               String          @id @default(uuid())
  flowNumber       String          @unique
  clueId           String
  caseId           String?
  title            String
  status           ClueCheckStatus @default(REGISTERED)
  currentStage     ClueCheckStage  @default(REGISTER)
  priority         String?

  registerContent  String?
  registerSource   String?
  registerLocation String?
  registerTime     DateTime?
  registerUserId   String?
  registerUserName String?
  registerUserDept String?

  dispatchTime     DateTime?
  dispatchUserId   String?
  dispatchUserName String?
  dispatchUserDept String?
  dispatchToUserId String?
  dispatchToUserName String?
  dispatchToUserDept String?
  dispatchDeadline DateTime?
  dispatchRemark   String?

  verifyTime       DateTime?
  verifyUserId     String?
  verifyUserName   String?
  verifyUserDept   String?
  verifyResult     String?
  verifyConclusion String?
  verifyLocation   String?
  verifyEvidenceIds String?

  feedbackTime     DateTime?
  feedbackUserId   String?
  feedbackUserName String?
  feedbackUserDept String?
  feedbackContent  String?
  feedbackResult   String?
  feedbackEvidenceIds String?

  adoptTime        DateTime?
  adoptUserId      String?
  adoptUserName    String?
  adoptUserDept    String?
  adoptResult      String?
  adoptOpinion     String?
  adoptToCaseId    String?
  adoptEvidenceIds String?

  rejectTime       DateTime?
  rejectUserId     String?
  rejectUserName   String?
  rejectUserDept   String?
  rejectReason     String?

  closeTime        DateTime?
  closeUserId      String?
  closeUserName    String?
  closeUserDept    String?
  closeReason      String?

  clue             Clue            @relation(fields: [clueId], references: [id])
  case             Case?           @relation(fields: [caseId], references: [id])
  operationLogs    ClueCheckLog[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([clueId])
  @@index([caseId])
  @@index([status])
  @@index([currentStage])
  @@index([createdAt])
}

model ClueCheckLog {
  id            String          @id @default(uuid())
  flowId        String
  stage         ClueCheckStage
  action        String
  description   String?
  beforeData    String?
  afterData     String?
  operatorId    String?
  operatorName  String?
  operatorDept  String?
  ip            String?
  userAgent     String?
  flow          ClueCheckFlow   @relation(fields: [flowId], references: [id], onDelete: Cascade)
  actionTime    DateTime        @default(now())
  createdAt     DateTime        @default(now())

  @@index([flowId])
  @@index([stage])
  @@index([actionTime])
}

enum FlowTargetType {
  CASE
  CLUE
  EVIDENCE
  PERSON
}

model CommandTask {
  id            String      @id @default(uuid())
  taskNumber    String      @unique
  title         String
  description   String
  taskType      TaskType
  priority      TaskPriority
  status        TaskStatus  @default(PENDING)
  progress      Int         @default(0)

  caseId        String?
  clueId        String?
  evidenceId    String?
  personId      String?

  assigneeId    String?
  assigneeName  String?
  assigneeDept  String?

  assignerId    String?
  assignerName  String?
  assignerDept  String?

  dueDate       DateTime?
  startDate     DateTime?
  completedDate DateTime?

  actualStart   DateTime?
  actualEnd     DateTime?

  location      String?
  requirement   String?
  result        String?
  note          String?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  case          Case?       @relation(fields: [caseId], references: [id])
  clue          Clue?       @relation(fields: [clueId], references: [id])
  evidence      Evidence?   @relation(fields: [evidenceId], references: [id])
  person        Person?     @relation(fields: [personId], references: [id])
  progresses    TaskProgress[]
  flowRecords   FlowRecord[] @relation("TaskFlow")

  @@index([caseId])
  @@index([clueId])
  @@index([evidenceId])
  @@index([personId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@index([dueDate])
}

model TaskProgress {
  id          String     @id @default(uuid())
  taskId      String
  progress    Int
  description String
  result      String?
  issue       String?
  suggestion  String?
  reporterId  String?
  reporterName String?
  progressDate DateTime?
  createdAt   DateTime   @default(now())

  task        CommandTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([createdAt])
}

model FlowRecord {
  id            String          @id @default(uuid())
  taskId        String?
  sourceType    FlowTargetType
  sourceId      String
  sourceName    String?
  sourceNumber  String?

  action        FlowAction
  description   String?

  fromUserId    String?
  fromUserName  String?
  fromUserDept  String?

  toUserId      String?
  toUserName    String?
  toUserDept    String?

  status        String?
  remark        String?

  operatorId    String?
  operatorName  String?
  operatorDept  String?

  actionTime    DateTime        @default(now())
  createdAt     DateTime        @default(now())

  task          CommandTask?    @relation("TaskFlow", fields: [taskId], references: [id])

  @@index([sourceType, sourceId])
  @@index([action])
  @@index([createdAt])
  @@index([fromUserId])
  @@index([toUserId])
}
