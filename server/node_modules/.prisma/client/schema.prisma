// 都市刑侦案件线索管理平台 - 数据模型
// 作者：刑侦系统开发组

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 案件信息表
model Case {
  id               String    @id @default(uuid())
  caseNumber       String    @unique
  title            String
  description      String
  caseType         String
  status           String
  priority         String
  location         String?
  occurTime        DateTime?
  reportTime       DateTime?
  caseManager      String?
  department       String?
  summary          String?
  caseAnalysis     String?
  personAnalysis   String?
  evidenceAnalysis String?
  conclusion       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  clues                 Clue[]
  evidences             Evidence[]
  casePersons           CasePerson[]
  personRelations       PersonRelation[]
  evidenceBorrows       EvidenceBorrow[]
  evidenceBatches       EvidenceBatch[]      @relation("BatchCase")
  evidenceTransfers     EvidenceTransfer[]
  sourceRelations       CaseRelation[]       @relation("SourceCase")
  targetRelations       CaseRelation[]       @relation("TargetCase")
  commandTasks          CommandTask[]
  meetingMinutes        CaseMeetingMinutes[]
  clueCheckFlows        ClueCheckFlow[]
  surveillanceRules     SurveillanceRule[]
  alerts                AlertMessage[]
  forensicBatches       ForensicBatch[]      @relation("ForensicBatchCase")
  forensicFiles         ForensicFile[]
  forensicFileRelations ForensicFileCase[]
}

// 人员信息表
model Person {
  id          String   @id @default(uuid())
  name        String
  gender      String?
  age         Int?
  idCard      String?  @unique
  phone       String?
  address     String?
  occupation  String?
  description String?
  avatar      String?
  personType  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  casePersons        CasePerson[]
  cluePersons        CluePerson[]
  relationsAsSubject PersonRelation[] @relation("SubjectRelations")
  relationsAsObject  PersonRelation[] @relation("ObjectRelations")
  personTags         PersonTag[]
  commandTasks       CommandTask[]
  alerts             AlertMessage[]
}

// 案件-人员关联表
model CasePerson {
  id        String   @id @default(uuid())
  caseId    String
  personId  String
  role      String
  note      String?
  createdAt DateTime @default(now())

  case   Case   @relation(fields: [caseId], references: [id])
  person Person @relation(fields: [personId], references: [id])

  @@unique([caseId, personId])
}

// 人员关系表
model PersonRelation {
  id           String   @id @default(uuid())
  subjectId    String
  objectId     String
  relationType String
  description  String?
  caseId       String?
  createdAt    DateTime @default(now())

  subjectPerson Person @relation("SubjectRelations", fields: [subjectId], references: [id])
  objectPerson  Person @relation("ObjectRelations", fields: [objectId], references: [id])
  case          Case?  @relation(fields: [caseId], references: [id])
}

// 线索信息表
model Clue {
  id          String    @id @default(uuid())
  caseId      String?
  clueNumber  String    @unique
  title       String
  content     String
  clueType    String
  source      String
  credibility String
  importance  String
  status      String
  location    String?
  findTime    DateTime?
  informant   String?
  handler     String?
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  case                  Case?              @relation(fields: [caseId], references: [id])
  evidences             Evidence[]
  cluePersons           CluePerson[]
  evidenceBorrows       EvidenceBorrow[]
  evidenceBatches       EvidenceBatch[]    @relation("BatchClue")
  evidenceTransfers     EvidenceTransfer[]
  verifications         ClueVerification[]
  commandTasks          CommandTask[]
  clueCheckFlows        ClueCheckFlow[]
  meetingClues          MeetingClue[]
  alerts                AlertMessage[]
  forensicBatches       ForensicBatch[]    @relation("ForensicBatchClue")
  forensicFiles         ForensicFile[]
  forensicFileRelations ForensicFileClue[]
}

// 线索-人员关联表
model CluePerson {
  id        String   @id @default(uuid())
  clueId    String
  personId  String
  relation  String
  note      String?
  createdAt DateTime @default(now())

  clue   Clue   @relation(fields: [clueId], references: [id])
  person Person @relation(fields: [personId], references: [id])

  @@unique([clueId, personId])
}

// 证据批次表
model EvidenceBatch {
  id               String    @id @default(uuid())
  batchNumber      String    @unique
  name             String?
  description      String?
  caseId           String?
  clueId           String?
  collectionMethod String?
  collector        String?
  collectTime      DateTime?
  location         String?
  status           String    @default("已入库")
  totalCount       Int       @default(0)
  successCount     Int       @default(0)
  failCount        Int       @default(0)
  operator         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  case      Case?      @relation("BatchCase", fields: [caseId], references: [id])
  clue      Clue?      @relation("BatchClue", fields: [clueId], references: [id])
  evidences Evidence[]
}

// 证据附件表
model Evidence {
  id                 String    @id @default(uuid())
  batchId            String?
  caseId             String?
  clueId             String?
  clueVerificationId String?
  evidenceNumber     String    @unique
  name               String
  description        String?
  type               String
  filePath           String
  fileName           String
  fileSize           Int?
  mimeType           String?
  hash               String?
  collectionMethod   String?
  collector          String?
  collectTime        DateTime?
  location           String?
  status             String
  borrowStatus       String?   @default("未借阅")
  currentBorrower    String?
  borrowTime         DateTime?
  note               String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  batch            EvidenceBatch?     @relation(fields: [batchId], references: [id])
  case             Case?              @relation(fields: [caseId], references: [id])
  clue             Clue?              @relation(fields: [clueId], references: [id])
  clueVerification ClueVerification?  @relation(fields: [clueVerificationId], references: [id])
  borrowRecords    EvidenceBorrow[]
  transfers        EvidenceTransfer[]
  commandTasks     CommandTask[]
  meetingEvidences MeetingEvidence[]
  alerts           AlertMessage[]
}

// 证据流转类型枚举
enum EvidenceTransferType {
  STORAGE_IN
  BORROW
  TRANSFER
  RETURN
  DESTROY
  SEAL
  UNSEAL
}

// 证据流转状态枚举
enum EvidenceTransferStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
  CANCELLED
}

// 证据流转记录表 - 管理入库、借阅、移交、归还、销毁全流程
model EvidenceTransfer {
  id             String                 @id @default(uuid())
  transferNumber String                 @unique
  evidenceId     String
  caseId         String?
  clueId         String?
  transferType   EvidenceTransferType
  status         EvidenceTransferStatus @default(PENDING)
  priority       String?

  fromDepartment String?
  fromPerson     String?
  toDepartment   String?
  toPerson       String?

  reason       String?
  description  String?
  expectedTime DateTime?
  actualTime   DateTime?

  applicant     String?
  applicantDept String?
  applyTime     DateTime @default(now())

  approver       String?
  approverDept   String?
  approveTime    DateTime?
  approveOpinion String?

  handler     String?
  handlerDept String?
  handleTime  DateTime?

  receiver      String?
  receiverDept  String?
  receiveTime   DateTime?
  receiveRemark String?

  returner     String?
  returnerDept String?
  returnTime   DateTime?
  returnRemark String?

  destroyMethod      String?
  destroySupervisor  String?
  destroyWitness     String?
  destroyCertificate String?

  operator      String?
  operatorDept  String?
  operationTime DateTime @default(now())

  evidence Evidence              @relation(fields: [evidenceId], references: [id])
  case     Case?                 @relation(fields: [caseId], references: [id])
  clue     Clue?                 @relation(fields: [clueId], references: [id])
  flowLogs EvidenceTransferLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([evidenceId])
  @@index([transferType])
  @@index([status])
  @@index([createdAt])
  @@index([fromPerson])
  @@index([toPerson])
  @@index([applicant])
}

// 证据流转日志表 - 记录流转过程中的每一步操作，用于责任追踪
model EvidenceTransferLog {
  id           String   @id @default(uuid())
  transferId   String
  action       String
  stage        String?
  description  String?
  beforeStatus String?
  afterStatus  String?
  operatorId   String?
  operatorName String?
  operatorDept String?
  ip           String?
  userAgent    String?
  actionTime   DateTime @default(now())
  remark       String?

  transfer EvidenceTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([transferId])
  @@index([action])
  @@index([actionTime])
  @@index([operatorName])
}

// 证据借阅记录表
model EvidenceBorrow {
  id                 String    @id @default(uuid())
  evidenceId         String
  caseId             String?
  clueId             String?
  borrower           String
  borrowerDepartment String?
  borrowReason       String
  borrowTime         DateTime  @default(now())
  expectedReturnTime DateTime?
  actualReturnTime   DateTime?
  status             String    @default("借阅中")
  returnNote         String?
  operator           String?
  returnOperator     String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  evidence Evidence @relation(fields: [evidenceId], references: [id])
  case     Case?    @relation(fields: [caseId], references: [id])
  clue     Clue?    @relation(fields: [clueId], references: [id])
}

// 线索核查记录表
model ClueVerification {
  id            String    @id @default(uuid())
  clueId        String
  result        String
  attachmentIds String?
  handler       String?
  handleTime    DateTime?
  note          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  clue      Clue       @relation(fields: [clueId], references: [id])
  evidences Evidence[]

  @@index([clueId])
  @@index([createdAt])
}

// 操作日志表
model OperationLog {
  id                 String   @id @default(uuid())
  targetType         String
  targetId           String
  action             String
  description        String?
  operator           String?
  operatorDepartment String?
  beforeData         String?
  afterData          String?
  ip                 String?
  userAgent          String?
  createdAt          DateTime @default(now())

  @@index([targetType, targetId])
  @@index([action])
  @@index([createdAt])
}

model CaseRelation {
  id           String   @id @default(uuid())
  sourceCaseId String
  targetCaseId String
  relationType String   @default("专题关联")
  description  String?
  createdAt    DateTime @default(now())

  sourceCase Case @relation("SourceCase", fields: [sourceCaseId], references: [id])
  targetCase Case @relation("TargetCase", fields: [targetCaseId], references: [id])

  @@unique([sourceCaseId, targetCaseId])
}

model Tag {
  id        String   @id @default(uuid())
  name      String
  category  String
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  personTags PersonTag[]

  @@unique([name, category])
}

model PersonTag {
  id        String   @id @default(uuid())
  personId  String
  tagId     String
  createdAt DateTime @default(now())

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([personId, tagId])
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  OVERDUE
}

enum TaskType {
  CASE_INVESTIGATION
  CLUE_VERIFICATION
  EVIDENCE_COLLECTION
  PERSON_INTERROGATION
  ANALYSIS_REPORT
  COORDINATION
  OTHER
}

enum FlowAction {
  ASSIGN
  TRANSFER
  RECEIVE
  RETURN
  APPROVE
  REJECT
  ARCHIVE
  UNARCHIVE
}

enum ClueCheckStatus {
  REGISTERED
  DISPATCHED
  VERIFYING
  FEEDBACKED
  ADOPTED
  REJECTED
  CLOSED
}

enum ClueCheckStage {
  REGISTER
  DISPATCH
  VERIFY
  FEEDBACK
  ADOPT
}

model ClueCheckFlow {
  id           String          @id @default(uuid())
  flowNumber   String          @unique
  clueId       String
  caseId       String?
  title        String
  status       ClueCheckStatus @default(REGISTERED)
  currentStage ClueCheckStage  @default(REGISTER)
  priority     String?

  registerContent  String?
  registerSource   String?
  registerLocation String?
  registerTime     DateTime?
  registerUserId   String?
  registerUserName String?
  registerUserDept String?

  dispatchTime       DateTime?
  dispatchUserId     String?
  dispatchUserName   String?
  dispatchUserDept   String?
  dispatchToUserId   String?
  dispatchToUserName String?
  dispatchToUserDept String?
  dispatchDeadline   DateTime?
  dispatchRemark     String?

  verifyTime        DateTime?
  verifyUserId      String?
  verifyUserName    String?
  verifyUserDept    String?
  verifyResult      String?
  verifyConclusion  String?
  verifyLocation    String?
  verifyEvidenceIds String?

  feedbackTime        DateTime?
  feedbackUserId      String?
  feedbackUserName    String?
  feedbackUserDept    String?
  feedbackContent     String?
  feedbackResult      String?
  feedbackEvidenceIds String?

  adoptTime        DateTime?
  adoptUserId      String?
  adoptUserName    String?
  adoptUserDept    String?
  adoptResult      String?
  adoptOpinion     String?
  adoptToCaseId    String?
  adoptEvidenceIds String?

  rejectTime     DateTime?
  rejectUserId   String?
  rejectUserName String?
  rejectUserDept String?
  rejectReason   String?

  closeTime     DateTime?
  closeUserId   String?
  closeUserName String?
  closeUserDept String?
  closeReason   String?

  clue          Clue           @relation(fields: [clueId], references: [id])
  case          Case?          @relation(fields: [caseId], references: [id])
  operationLogs ClueCheckLog[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([clueId])
  @@index([caseId])
  @@index([status])
  @@index([currentStage])
  @@index([createdAt])
}

model ClueCheckLog {
  id           String         @id @default(uuid())
  flowId       String
  stage        ClueCheckStage
  action       String
  description  String?
  beforeData   String?
  afterData    String?
  operatorId   String?
  operatorName String?
  operatorDept String?
  ip           String?
  userAgent    String?
  flow         ClueCheckFlow  @relation(fields: [flowId], references: [id], onDelete: Cascade)
  actionTime   DateTime       @default(now())
  createdAt    DateTime       @default(now())

  @@index([flowId])
  @@index([stage])
  @@index([actionTime])
}

enum FlowTargetType {
  CASE
  CLUE
  EVIDENCE
  PERSON
}

model CommandTask {
  id          String       @id @default(uuid())
  taskNumber  String       @unique
  title       String
  description String
  taskType    TaskType
  priority    TaskPriority
  status      TaskStatus   @default(PENDING)
  progress    Int          @default(0)

  caseId     String?
  clueId     String?
  evidenceId String?
  personId   String?

  assigneeId   String?
  assigneeName String?
  assigneeDept String?

  assignerId   String?
  assignerName String?
  assignerDept String?

  dueDate       DateTime?
  startDate     DateTime?
  completedDate DateTime?

  actualStart DateTime?
  actualEnd   DateTime?

  location    String?
  requirement String?
  result      String?
  note        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  case             Case?             @relation(fields: [caseId], references: [id])
  clue             Clue?             @relation(fields: [clueId], references: [id])
  evidence         Evidence?         @relation(fields: [evidenceId], references: [id])
  person           Person?           @relation(fields: [personId], references: [id])
  progresses       TaskProgress[]
  flowRecords      FlowRecord[]      @relation("TaskFlow")
  meetingTodoItems MeetingTodoItem[]

  @@index([caseId])
  @@index([clueId])
  @@index([evidenceId])
  @@index([personId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@index([dueDate])
}

model TaskProgress {
  id           String    @id @default(uuid())
  taskId       String
  progress     Int
  description  String
  result       String?
  issue        String?
  suggestion   String?
  reporterId   String?
  reporterName String?
  progressDate DateTime?
  createdAt    DateTime  @default(now())

  task CommandTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([createdAt])
}

model FlowRecord {
  id           String         @id @default(uuid())
  taskId       String?
  sourceType   FlowTargetType
  sourceId     String
  sourceName   String?
  sourceNumber String?

  action      FlowAction
  description String?

  fromUserId   String?
  fromUserName String?
  fromUserDept String?

  toUserId   String?
  toUserName String?
  toUserDept String?

  status String?
  remark String?

  operatorId   String?
  operatorName String?
  operatorDept String?

  actionTime DateTime @default(now())
  createdAt  DateTime @default(now())

  task CommandTask? @relation("TaskFlow", fields: [taskId], references: [id])

  @@index([sourceType, sourceId])
  @@index([action])
  @@index([createdAt])
  @@index([fromUserId])
  @@index([toUserId])
}

enum MeetingStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MeetingTodoStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model CaseMeetingMinutes {
  id            String        @id @default(uuid())
  meetingNumber String        @unique
  caseId        String
  title         String
  meetingType   String
  status        MeetingStatus @default(DRAFT)
  location      String?
  meetingTime   DateTime?
  hostId        String?
  hostName      String?
  hostDept      String?
  recorderId    String?
  recorderName  String?
  recorderDept  String?

  caseAnalysis      String?
  clueAnalysis      String?
  evidenceAnalysis  String?
  personAnalysis    String?
  discussionContent String?
  conclusion        String?
  note              String?

  operatorId   String?
  operatorName String?
  operatorDept String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  case              Case              @relation(fields: [caseId], references: [id])
  attendees         MeetingAttendee[]
  clueRelations     MeetingClue[]
  evidenceRelations MeetingEvidence[]
  todoItems         MeetingTodoItem[]

  @@index([caseId])
  @@index([status])
  @@index([meetingTime])
  @@index([createdAt])
}

model MeetingAttendee {
  id         String   @id @default(uuid())
  meetingId  String
  personId   String?
  personName String
  personDept String?
  role       String?
  note       String?
  createdAt  DateTime @default(now())

  meeting CaseMeetingMinutes @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, personId])
  @@index([meetingId])
  @@index([personId])
}

model MeetingClue {
  id              String   @id @default(uuid())
  meetingId       String
  clueId          String
  discussionPoint String?
  conclusion      String?
  createdAt       DateTime @default(now())

  meeting CaseMeetingMinutes @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  clue    Clue               @relation(fields: [clueId], references: [id])

  @@unique([meetingId, clueId])
  @@index([meetingId])
  @@index([clueId])
}

model MeetingEvidence {
  id              String   @id @default(uuid())
  meetingId       String
  evidenceId      String
  discussionPoint String?
  conclusion      String?
  createdAt       DateTime @default(now())

  meeting  CaseMeetingMinutes @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  evidence Evidence           @relation(fields: [evidenceId], references: [id])

  @@unique([meetingId, evidenceId])
  @@index([meetingId])
  @@index([evidenceId])
}

model MeetingTodoItem {
  id           String            @id @default(uuid())
  meetingId    String
  title        String
  description  String?
  priority     String
  dueDate      DateTime?
  assigneeId   String?
  assigneeName String?
  assigneeDept String?
  status       MeetingTodoStatus @default(PENDING)
  taskId       String?
  note         String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  meeting CaseMeetingMinutes @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  task    CommandTask?       @relation(fields: [taskId], references: [id])

  @@index([meetingId])
  @@index([status])
  @@index([assigneeId])
  @@index([dueDate])
}

enum SurveillanceTargetType {
  PERSON
  LOCATION
  EVIDENCE
}

enum SurveillanceRuleStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

enum AlertLevel {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AlertStatus {
  PENDING
  PROCESSING
  RESOLVED
  DISMISSED
  ESCALATED
}

enum DisposalType {
  VERIFY
  MONITOR
  INVESTIGATE
  ASSIGN_TASK
  DISMISS
  ESCALATE
  OTHER
}

model SurveillanceRule {
  id               String                 @id @default(uuid())
  ruleNumber       String                 @unique
  name             String
  description      String?
  targetType       SurveillanceTargetType
  targetIds        String?
  locationKeywords String?
  conditions       String?
  alertLevel       AlertLevel             @default(MEDIUM)
  notifyChannels   String?
  notifyUsers      String?
  validFrom        DateTime?
  validTo          DateTime?
  status           SurveillanceRuleStatus @default(ACTIVE)
  caseId           String?
  operatorId       String?
  operatorName     String?
  operatorDept     String?
  triggerCount     Int                    @default(0)
  lastTriggerTime  DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  case   Case?          @relation(fields: [caseId], references: [id])
  alerts AlertMessage[]

  @@index([targetType])
  @@index([status])
  @@index([alertLevel])
  @@index([caseId])
  @@index([createdAt])
}

model AlertMessage {
  id            String                 @id @default(uuid())
  alertNumber   String                 @unique
  ruleId        String?
  title         String
  content       String
  targetType    SurveillanceTargetType
  targetId      String?
  targetName    String?
  alertLevel    AlertLevel             @default(MEDIUM)
  status        AlertStatus            @default(PENDING)
  triggerSource String?
  triggerTime   DateTime               @default(now())
  caseId        String?
  clueId        String?
  evidenceId    String?
  personId      String?
  location      String?
  metadata      String?
  assigneeId    String?
  assigneeName  String?
  assigneeDept  String?
  resolveTime   DateTime?
  resolveNote   String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  rule      SurveillanceRule? @relation(fields: [ruleId], references: [id])
  case      Case?             @relation(fields: [caseId], references: [id])
  clue      Clue?             @relation(fields: [clueId], references: [id])
  evidence  Evidence?         @relation(fields: [evidenceId], references: [id])
  person    Person?           @relation(fields: [personId], references: [id])
  disposals AlertDisposal[]

  @@index([ruleId])
  @@index([status])
  @@index([alertLevel])
  @@index([targetType])
  @@index([caseId])
  @@index([personId])
  @@index([triggerTime])
  @@index([createdAt])
}

model AlertDisposal {
  id           String       @id @default(uuid())
  alertId      String
  disposalType DisposalType
  title        String
  description  String?
  result       String?
  operatorId   String?
  operatorName String?
  operatorDept String?
  disposalTime DateTime     @default(now())
  nextAction   String?
  taskId       String?
  attachments  String?
  createdAt    DateTime     @default(now())

  alert AlertMessage @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@index([alertId])
  @@index([disposalType])
  @@index([operatorId])
  @@index([disposalTime])
}

enum ForensicFileType {
  DOCUMENT
  IMAGE
  VIDEO
  AUDIO
  EMAIL
  DATABASE
  LOG
  ARCHIVE
  CODE
  SYSTEM_FILE
  OTHER
}

enum ForensicAcquisitionMethod {
  DISK_IMAGE
  FILE_COPY
  MEMORY_DUMP
  NETWORK_CAPTURE
  EMAIL_EXPORT
  DATABASE_EXTRACT
  LOG_EXPORT
  CLOUD_SYNC
  MANUAL_COLLECT
  OTHER
}

enum ForensicIntegrityStatus {
  VERIFIED
  CORRUPTED
  PENDING
  NOT_APPLICABLE
}

model ForensicBatch {
  id                  String                    @id @default(uuid())
  batchNumber         String                    @unique
  name                String
  description         String?
  caseId              String?
  clueId              String?
  acquisitionMethod   ForensicAcquisitionMethod
  acquirer            String?
  acquisitionTime     DateTime?
  acquisitionLocation String?
  deviceInfo          String?
  storageDevice       String?
  writeBlockerUsed    Boolean                   @default(false)
  chainOfCustodyNote  String?
  status              String                    @default("处理中")
  totalFileCount      Int                       @default(0)
  successCount        Int                       @default(0)
  failCount           Int                       @default(0)
  operatorId          String?
  operatorName        String?
  operatorDept        String?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  case              Case?                      @relation("ForensicBatchCase", fields: [caseId], references: [id])
  clue              Clue?                      @relation("ForensicBatchClue", fields: [clueId], references: [id])
  forensicFiles     ForensicFile[]
  hashVerifications ForensicHashVerification[]
  operationLogs     ForensicOperationLog[]

  @@index([caseId])
  @@index([clueId])
  @@index([status])
  @@index([createdAt])
}

model ForensicFile {
  id                   String                     @id @default(uuid())
  batchId              String?
  caseId               String?
  clueId               String?
  forensicNumber       String                     @unique
  originalPath         String
  fileName             String
  fileExtension        String?
  fileType             ForensicFileType
  fileSize             Int
  mimeType             String?
  storagePath          String
  md5Hash              String?
  sha1Hash             String?
  sha256Hash           String?
  integrityStatus      ForensicIntegrityStatus    @default(PENDING)
  lastVerificationTime DateTime?
  verificationCount    Int                        @default(0)
  metadata             String?
  acquisitionMethod    ForensicAcquisitionMethod?
  acquirer             String?
  acquisitionTime      DateTime?
  acquisitionLocation  String?
  sourceDevice         String?
  fileCreatedTime      DateTime?
  fileModifiedTime     DateTime?
  fileAccessedTime     DateTime?
  description          String?
  analysisNotes        String?
  tags                 String?
  isDeleted            Boolean                    @default(false)
  deletedAt            DateTime?
  operatorId           String?
  operatorName         String?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  batch             ForensicBatch?             @relation(fields: [batchId], references: [id])
  case              Case?                      @relation(fields: [caseId], references: [id])
  clue              Clue?                      @relation(fields: [clueId], references: [id])
  hashVerifications ForensicHashVerification[]
  clueRelations     ForensicFileClue[]
  caseRelations     ForensicFileCase[]
  operationLogs     ForensicOperationLog[]

  @@index([batchId])
  @@index([caseId])
  @@index([clueId])
  @@index([forensicNumber])
  @@index([fileType])
  @@index([integrityStatus])
  @@index([md5Hash])
  @@index([sha256Hash])
  @@index([createdAt])
}

model ForensicHashVerification {
  id               String                  @id @default(uuid())
  forensicFileId   String?
  batchId          String?
  verificationType String
  originalMd5      String?
  originalSha1     String?
  originalSha256   String?
  currentMd5       String?
  currentSha1      String?
  currentSha256    String?
  md5Match         Boolean?
  sha1Match        Boolean?
  sha256Match      Boolean?
  overallResult    ForensicIntegrityStatus
  verificationTime DateTime                @default(now())
  verifierId       String?
  verifierName     String?
  verifierDept     String?
  algorithmVersion String?
  verificationTool String?
  note             String?

  forensicFile ForensicFile?  @relation(fields: [forensicFileId], references: [id])
  batch        ForensicBatch? @relation(fields: [batchId], references: [id])

  @@index([forensicFileId])
  @@index([batchId])
  @@index([overallResult])
  @@index([verificationTime])
}

model ForensicFileCase {
  id             String   @id @default(uuid())
  forensicFileId String
  caseId         String
  relationType   String   @default("关联证据")
  description    String?
  bindTime       DateTime @default(now())
  operatorId     String?
  operatorName   String?

  forensicFile ForensicFile @relation(fields: [forensicFileId], references: [id], onDelete: Cascade)
  case         Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@unique([forensicFileId, caseId])
  @@index([caseId])
}

model ForensicFileClue {
  id             String   @id @default(uuid())
  forensicFileId String
  clueId         String
  relationType   String   @default("关联线索")
  description    String?
  bindTime       DateTime @default(now())
  operatorId     String?
  operatorName   String?

  forensicFile ForensicFile @relation(fields: [forensicFileId], references: [id], onDelete: Cascade)
  clue         Clue         @relation(fields: [clueId], references: [id], onDelete: Cascade)

  @@unique([forensicFileId, clueId])
  @@index([clueId])
}

model ForensicOperationLog {
  id             String   @id @default(uuid())
  targetType     String
  targetId       String
  forensicFileId String?
  batchId        String?
  action         String
  description    String?
  beforeData     String?
  afterData      String?
  operatorId     String?
  operatorName   String?
  operatorDept   String?
  ip             String?
  userAgent      String?
  operationTime  DateTime @default(now())
  remark         String?

  forensicFile ForensicFile?  @relation(fields: [forensicFileId], references: [id])
  batch        ForensicBatch? @relation(fields: [batchId], references: [id])

  @@index([targetType, targetId])
  @@index([forensicFileId])
  @@index([batchId])
  @@index([action])
  @@index([operationTime])
}
